# General

font-family = "JetBrainsMono Nerd Font"
font-size = 16
# theme = Dark Modern
# theme = rose-pine
# theme = Breeze
theme = Hybrid
# theme = Later This Evening
# theme = Miasma
# theme = Elegant
# theme = Wilmersdorf
# theme = Idea

# background = #000
background-opacity = 0.8
# selection-background = #eeeeee
selection-background = #0b3fa8

gtk-titlebar = false
confirm-close-surface=false
shell-integration = zsh
tab-inherit-working-directory = false
split-inherit-working-directory = false
window-inherit-working-directory = false

# Binds

keybind = f3=scroll_page_lines:-1
keybind = f4=scroll_page_lines:1
keybind = home=scroll_to_top
keybind = end=scroll_to_bottom
keybind = ctrl+shift+x=clear_screen
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+t=unbind
keybind = ctrl+shift+e=unbind
